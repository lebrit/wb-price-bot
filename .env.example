# Несекретные настройки. Токен Telegram и ключ шифрования подключаются файлами.
TELEGRAM_ALLOWED_USERS=123456789
CHECK_INTERVAL_SECONDS=1800
CHECK_JITTER_SECONDS=120
MAX_PRODUCTS_PER_USER=200
MAX_WB_BATCH_SIZE=25
# Иркутск. Для другого региона задайте свой dest из xinfo Wildberries.
WB_DESTINATION=-5827722
WB_CURRENCY=rub
WB_LANGUAGE=ru
PRICE_HISTORY_DAYS=180
LOG_LEVEL=INFO
WB_BROWSER_HEADLESS=false
APP_TIMEZONE=Asia/Irkutsk
MAX_BULK_IMPORT=50
MAX_RULES_PER_PRODUCT=10
MPSTATS_MAX_AGE_HOURS=24

# Для локальной разработки вместо *_FILE можно задать значения напрямую:
# TELEGRAM_BOT_TOKEN=123456:ABC...
# SESSION_ENCRYPTION_KEY=base64-fernet-key
# MPSTATS_TOKEN=optional-licensed-api-token
