{$AUTH_DOMAIN} {
    encode zstd gzip
    reverse_proxy auth:8080

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        -Server
    }

    log {
        output stdout
        format json
    }
}
