{
  "manifest_version": 3,
  "name": "WB Price Bot Connector",
  "version": "0.4.0",
  "description": "Одноразовое безопасное подключение аккаунта Wildberries к WB Price Bot.",
  "permissions": ["cookies", "scripting", "storage", "tabs", "webRequest"],
  "host_permissions": [
    "https://wildberries.ru/*",
    "https://*.wildberries.ru/*",
    "https://wb.ru/*",
    "https://*.wb.ru/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "WB Price Bot Connector",
    "default_popup": "popup.html"
  }
}
